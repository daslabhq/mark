  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".":                            "./src/index.ts",
    "./check":                      "./src/check.ts",
    "./evaluate":                   "./src/evaluate.ts",
    "./path":                       "./src/path.ts",
    "./tools":                      "./src/tools.ts",
    "./translate/automationbench":  "./src/translate/automationbench.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daslabhq/autocheck.git"
  },
  "homepage": "https://github.com/daslabhq/autocheck#readme",
  "bugs": {
    "url": "https://github.com/daslabhq/autocheck/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "bun test src/"
  },
  "keywords": [
    "agent",
    "ai",
    "llm",
    "scene",
    "check",
    "evaluation",
    "predicate",
    "goal",
